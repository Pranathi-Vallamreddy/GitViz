# --- API server (packages/server) ---
# Copy to .env for local dev; on Render/Fly set these as service env vars.

PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# Allowed web origin(s): "*" (public demo), one URL, or a comma-separated list.
CORS_ORIGIN=http://localhost:5173

# Repository the API visualizes. Auto-seeded with a demo history if empty.
GITVIZ_REPO=./demo-repo
# Set to "false" to disable the demo auto-seed (e.g. pointing at a real repo).
# GITVIZ_SEED=true

# --- Web client (packages/web, build-time) ---
# Base origin of the deployed API. Empty in dev (Vite proxies /api).
# On Vercel set: VITE_API_URL=https://gitviz-api.onrender.com
# VITE_API_URL=
