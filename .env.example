# Copy to .env and fill in. Loaded by packages/server.

# --- Server ---
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# CORS origin for the web client (Vite dev server default shown).
CORS_ORIGIN=http://localhost:5173

# --- Auth (Phase 2) ---
JWT_SECRET=change-me-in-production

# --- Database: Postgres metadata store (Phase 2) ---
# Objects (blobs/trees/commits) live in the content-addressable store, NOT here.
DATABASE_URL=postgresql://gitviz:gitviz@localhost:5432/gitviz?schema=public

# --- Object store ---
# Filesystem root for the content-addressable object store.
GITVIZ_DATA_DIR=./.gitviz-data
