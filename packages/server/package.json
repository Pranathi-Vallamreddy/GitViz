{
  "name": "@gitviz/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "GitViz HTTP API (Fastify) exposing the version-control engine and Postgres-backed metadata.",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch --conditions development src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -b",
    "typecheck": "tsc -b",
    "clean": "rimraf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@gitviz/core": "workspace:*",
    "@gitviz/shared": "workspace:*",
    "fastify": "^5.2.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "tsx": "^4.19.2"
  }
}
